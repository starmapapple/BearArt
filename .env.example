NEXT_PUBLIC_SITE_URL=https://your-preview-or-domain.example
NEXT_PUBLIC_SUPPORT_WHATSAPP=6285215448518
# Optional: later switch /uploads and /icons to a CDN without changing page content.
# Example: https://cdn.grupbeli.com
NEXT_PUBLIC_ASSET_BASE_URL=
# Optional: Vercel Deploy Hook for the admin "发布线上" button.
VERCEL_DEPLOY_HOOK_URL=

# Admin security
ADMIN_PASSWORD=replace-with-a-long-password
ADMIN_SESSION_SECRET=replace-with-a-random-secret

# Payment provider: cod_only for phase 1 COD-only launch; later switch to xendit or midtrans for VA.
PAYMENT_PROVIDER=cod_only
PAYMENT_WEBHOOK_SECRET=
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false

# Future database migration
DATABASE_URL=postgres://user:password@host:5432/database

# Logistics: keep disabled until Biteship KYC/COD and Order API are activated.
LOGISTICS_PROVIDER=disabled
BITESHIP_API_KEY=
# Configure the same token as Bearer auth in the Biteship webhook settings.
BITESHIP_WEBHOOK_TOKEN=
LOGISTICS_ORIGIN_CONTACT_NAME=
LOGISTICS_ORIGIN_CONTACT_PHONE=
LOGISTICS_ORIGIN_ADDRESS=
LOGISTICS_ORIGIN_POSTAL_CODE=
LOGISTICS_DEFAULT_COURIER=sicepat
LOGISTICS_DEFAULT_COURIER_TYPE=reg
LOGISTICS_DEFAULT_WEIGHT_GRAMS=1000
LOGISTICS_DEFAULT_LENGTH_CM=30
LOGISTICS_DEFAULT_WIDTH_CM=25
LOGISTICS_DEFAULT_HEIGHT_CM=10
LOGISTICS_COD_DISBURSEMENT=7_days
